# Local-dev env. Production reads from /etc/peer39-mcp/connector.env.

PORT=3001
PUBLIC_URL=http://localhost:3001

# 32 bytes, base64-encoded. Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# 32 bytes, hex-encoded. Generate with: openssl rand -hex 32
SESSION_SECRET=

DATA_DIR=./tmp

PEER39_BASE_URL=https://app.peer39.com
LOG_LEVEL=info
