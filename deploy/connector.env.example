# Production env file. Lives at /etc/peer39-mcp/connector.env on the droplet
# (mode 0640, owner root:peer39mcp).

PORT=3001
PUBLIC_URL=https://peer39-mcp.example.com

# 32 bytes, base64. Generate ONCE on the droplet:
#   openssl rand -base64 32
# Losing or rotating this key invalidates every saved credential row.
ENCRYPTION_KEY=

# 32 bytes, hex. For signing the OAuth user-session cookie.
#   openssl rand -hex 32
SESSION_SECRET=

DATA_DIR=/var/lib/peer39-mcp
LOG_LEVEL=info
PEER39_BASE_URL=https://app.peer39.com
